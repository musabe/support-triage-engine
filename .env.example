# ── Claude / Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5

# ── Freshdesk ────────────────────────────────────────────────────────────────
# Your domain WITHOUT https:// — e.g. yourcompany.freshdesk.com
FRESHDESK_DOMAIN=yourcompany.freshdesk.com

# API key from: Freshdesk → Profile Settings → API Key
FRESHDESK_API_KEY=your_freshdesk_api_key_here

# Optional: for webhook signature verification (leave blank to skip)
FRESHDESK_WEBHOOK_SECRET=

# ── Jira Cloud ───────────────────────────────────────────────────────────────
# Your domain WITHOUT https:// — e.g. yourcompany.atlassian.net
JIRA_DOMAIN=yourcompany.atlassian.net

# Your Jira account email
JIRA_EMAIL=you@yourcompany.com

# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# Comma-separated issue types to triage (others will be skipped)
JIRA_ISSUE_TYPES=Incident,Support

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://triage:triage@localhost:5432/triage

# ── Server ───────────────────────────────────────────────────────────────────
DEBUG=false

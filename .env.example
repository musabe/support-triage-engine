# ── Claude / Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Freshdesk ────────────────────────────────────────────────────────────────
# Your domain WITHOUT https:// — e.g. yourcompany.freshdesk.com
FRESHDESK_DOMAIN=yourcompany.freshdesk.com

# API key from: Freshdesk → Profile Settings → API Key
FRESHDESK_API_KEY=your_freshdesk_api_key_here

# Optional: for webhook signature verification (leave blank to skip)
FRESHDESK_WEBHOOK_SECRET=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by the FastAPI server; Docker Compose sets this automatically
DATABASE_URL=postgresql://triage:triage@localhost:5432/triage

# ── Server ───────────────────────────────────────────────────────────────────
DEBUG=false
